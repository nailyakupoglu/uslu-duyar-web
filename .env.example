# Eren Tarım — ortam değişkenleri örneği
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.

# Site temel URL'i (metadata, sitemap, JSON-LD için)
NEXT_PUBLIC_SITE_URL=https://erentarim.com

# Analytics sağlayıcı: "ga4" | "plausible" (boş = kapalı)
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# İletişim formu e-posta gönderimi (Resend) — FAZ 9
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@erentarim.com
CONTACT_FROM_EMAIL=web@erentarim.com
