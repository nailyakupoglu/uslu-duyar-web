# Uslu Duyar — ortam değişkenleri örneği
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.

# Site temel URL'i (metadata, sitemap, JSON-LD için)
NEXT_PUBLIC_SITE_URL=https://usluduyar.evohaus.org

# Analytics sağlayıcı: "ga4" | "plausible" (boş = kapalı)
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# İletişim/teklif formu — n8n webhook (e-posta + WhatsApp bildirimi)
N8N_CONTACT_WEBHOOK_URL=https://nail.n8n.evohaus.org/webhook/usluduyar-contact
N8N_CONTACT_WEBHOOK_SECRET=
CONTACT_TO_EMAIL=info@usluduyar.com
